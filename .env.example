# VeriPath Bridge Engine — Credentials Template
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub

# KenTrade Portal
KENTRADE_USERNAME=your_kentrade_username
KENTRADE_PASSWORD=your_kentrade_password

# KEPHIS Portal
KEPHIS_USERNAME=your_kephis_username
KEPHIS_PASSWORD=your_kephis_password

# AFA IMIS Portal
AFA_USERNAME=your_afa_username
AFA_PASSWORD=your_afa_password

# Mode override (set to "real" to force real submission)
BRIDGE_MODE=simulation
